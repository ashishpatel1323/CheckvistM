{
  "expo": {
    "name": "Checkvist",
    "slug": "checkvist-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./public/icons/icon-512.png",
    "userInterfaceStyle": "light",
    "scheme": "checkvist",
    "splash": {
      "backgroundColor": "#E8632A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ashishpatel.checkvist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./public/icons/icon-192.png",
        "backgroundColor": "#E8632A"
      },
      "package": "com.ashishpatel.checkvist"
    },
    "web": {
      "bundler": "metro",
      "name": "Checkvist",
      "shortName": "Checkvist",
      "description": "Checkvist task manager",
      "themeColor": "#E8632A",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E8632A"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "newArchEnabled": true,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f0c7beb2-284a-4eea-b8ca-0f04229e0bb9"
      }
    }
  }
}
