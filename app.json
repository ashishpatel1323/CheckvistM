{
  "expo": {
    "name": "Checkvist",
    "slug": "checkvist-app",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/f0c7beb2-284a-4eea-b8ca-0f04229e0bb9",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "orientation": "portrait",
    "icon": "./public/icons/icon-512.png",
    "userInterfaceStyle": "light",
    "scheme": "checkvist",
    "splash": {
      "image": "./public/icons/icon-512.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C1C28"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ashishpatel.checkvist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./public/icons/adaptive-foreground.png",
        "backgroundColor": "#1C1C28"
      },
      "package": "com.ashishpatel.checkvist",
      "versionCode": 11,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./public/favicon.png",
      "name": "Checkvist",
      "shortName": "Checkvist",
      "description": "Checkvist task manager",
      "themeColor": "#E8632A",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./public/icons/icon-512.png",
          "resizeMode": "contain",
          "backgroundColor": "#E8632A"
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./public/icons/icon-192.png",
          "color": "#E8632A",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
    ],
    "experiments": {
      "typedRoutes": false
    },
    "newArchEnabled": true,
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f0c7beb2-284a-4eea-b8ca-0f04229e0bb9"
      }
    }
  }
}
