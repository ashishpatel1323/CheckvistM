{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "nativewind/types"
    ]
  },
  "include": [
    "app",
    "src",
    "*.config.js",
    "*.config.ts",
    "nativewind-env.d.ts"
  ]
}