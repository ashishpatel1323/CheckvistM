{
  "name": "checkvist-app",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "main": "expo-router/entry",
  "scripts": {
    "predev": "printf 'EXPO_PUBLIC_GIT_COMMIT=%s\\nEXPO_PUBLIC_GIT_DATE=%s\\n' \"$(git rev-parse --short HEAD)\" \"$(git log -1 --format=%ci)\" > .env.local",
    "dev": "expo start",
    "web": "expo start --web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:web": "EXPO_PUBLIC_GIT_COMMIT=$(git rev-parse --short HEAD) EXPO_PUBLIC_GIT_DATE=$(git log -1 --format=%ci) expo export --platform web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.4",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@shopify/flash-list": "^1.7.3",
    "@tanstack/query-async-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "axios": "^1.16.1",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.3",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-background-fetch": "^13.0.6",
    "expo-constants": "~17.0.8",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.1",
    "expo-linking": "~7.0.5",
    "expo-notifications": "^0.29.14",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "~0.29.21",
    "expo-status-bar": "~2.0.1",
    "expo-task-manager": "^12.0.6",
    "expo-updates": "~0.27.5",
    "lottie-web": "^5.13.0",
    "lucide-react-native": "^0.475.0",
    "marked": "^18.0.3",
    "nativewind": "^4.1.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.76.0",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.7",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native-community/netinfo": "^11.4.1",
    "@types/dompurify": "^3.2.0",
    "@types/marked": "^6.0.0",
    "@types/react": "~18.3.12",
    "@types/react-dom": "^18.3.0",
    "babel-preset-expo": "~12.0.10",
    "eslint": "^10.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2"
  }
}
