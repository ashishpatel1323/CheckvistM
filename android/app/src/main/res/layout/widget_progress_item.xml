<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:paddingStart="2dp"
    android:paddingEnd="2dp">

    <!-- Name row: color dot + name + pct -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <View
            android:id="@+id/progress_item_color_dot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="6dp"
            android:background="@drawable/widget_color_dot" />

        <TextView
            android:id="@+id/progress_item_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="#111827"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/progress_item_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Progress bar (colored background = track, ProgressBar = fill) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="5dp"
        android:layout_marginBottom="3dp">

        <View
            android:id="@+id/progress_item_bar_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <ProgressBar
            android:id="@+id/progress_item_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:max="100"
            android:progress="0"
            android:progressTint="#2B5BAD"
            android:progressBackgroundTint="#00000000" />
    </FrameLayout>

    <!-- Value row -->
    <TextView
        android:id="@+id/progress_item_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="#6B7280"
        android:layout_marginStart="14dp" />

</LinearLayout>
