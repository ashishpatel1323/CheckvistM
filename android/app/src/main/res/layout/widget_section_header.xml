<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="8dp"
    android:paddingBottom="4dp">

    <!-- Colored dot -->
    <View
        android:id="@+id/header_color_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/widget_color_dot"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="2dp" />

    <!-- Routine name -->
    <TextView
        android:id="@+id/header_routine_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/header_color_dot"
        android:layout_toStartOf="@id/header_pending_count"
        android:layout_centerVertical="true"
        android:layout_marginStart="8dp"
        android:textSize="12sp"
        android:textColor="#111827"
        android:textStyle="bold"
        android:singleLine="true"
        android:ellipsize="end" />

    <!-- Pending count badge -->
    <TextView
        android:id="@+id/header_pending_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:textSize="10sp"
        android:textColor="#6B7280"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp" />

</RelativeLayout>
